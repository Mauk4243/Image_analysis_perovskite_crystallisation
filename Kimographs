# find border in cropped kymograph
from skimage import filters
# Apply a Sobel filter to find edges in the kymograph
edges = filters.sobel(kymograph[190:900, len(kymograph[0])//2:])

# EDGES ACROSS THE ENTIRE WIDTH OF THE KYMOGRAPH
#edges = filters.sobel(kymograph[500:900, :])  # If you want to find edges across the entire width of the kymograph

plt.figure(figsize=(10, 5))
plt.imshow(edges, aspect='auto', cmap='viridis', extent=[0, spatial_size/2, 900, 190])

# entire width 
#plt.imshow(edges, aspect='auto', cmap='viridis', extent=[-spatial_size/2, spatial_size/2, 900, 190])
plt.ylabel("Time (s)")
plt.xlabel("Position ($\mu m$)")
plt.colorbar(label='Edge Strength')


# %%
# find highest position at each time point in the kymograph
border_positions = []

idx = 0
max_width = 12  # maximum width to look around the previous position to avoid noise
for edge in edges[190:900]:  #before we had t=190.! at first 
    if idx == 0:
        border_pos = np.argmax(edge)  # Find the index of the maximum value in the edge profile
        border_positions.append(border_pos * 9/30)
    else:
        # make sure the border is close to the previous position to avoid noise
        edge_around = edge[border_pos - max_width : border_pos + max_width]  # Look around the previous position
        if len(edge_around) == 0:  # If we are at the edge of the array, just take the max
            border_pos = np.argmax(edge)
            border_positions.append(border_pos * 9/30)
        else:
            border_pos = np.argmax(edge_around) + border_pos - max_width  # Update the border position
            border_positions.append(border_pos * 9/30)  # Convert pixel index to micrometers
    idx += 1


plt.figure(figsize=(10, 5))
time_arr = np.arange(len(border_positions)) / fps + 190  # Convert frame indices to time in seconds
plt.plot( time_arr, border_positions)
plt.xlabel("Time (s)", fontsize=16)
plt.ylabel("Border Position ($\mu m$)", fontsize=16)
plt.tick_params(axis='both', which='major', labelsize=15)
plt.xlim(190, 190+len(border_positions)/fps)  # Set x-axis limits to match the time range of the border positions
plt.ylim(5, 40)





# %%
# Fitting a polynomial to the border position over time to find the crystallisation time.

degree = 3  # quadratic, change to 3, 4, etc. if needed

coeffs = np.polyfit(time_arr, border_positions, degree)

fitted_values = np.polyval(coeffs, time_arr)

plt.figure(figsize=(10, 5))
plt.plot(time_arr, border_positions, '.', label='Border Position')
plt.plot(time_arr, fitted_values, 'r-', linewidth=2,
         label=f'Polynomial degree {degree}')

plt.xlabel("Time (s)", fontsize=16)
plt.ylabel("Border Position ($\mu m$)", fontsize=16)
plt.tick_params(axis='both', which='major', labelsize=15)
plt.ylim(5,40)
plt.legend()
plt.show()

