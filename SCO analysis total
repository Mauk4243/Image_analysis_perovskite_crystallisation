vertical_coords   = [(y, x0) for y in y_vals]
diag_coords       = list(zip(y_vals, x_vals))


# --- FUNCTION: find transition time ---
def get_transition_times(coords, sigma=2):
    data = np.array([images[:, y, x] for (y, x) in coords]).T

    # Smooth
    data = gaussian_filter1d(data, sigma=sigma, axis=0)

    # Normalize
    baseline = np.mean(data[10:20, :], axis=0)
    data = data - baseline

    t_trans = []

    for i in range(data.shape[1]):
        y = data[:, i]

        # Define 50% level
        y_min = np.min(y)
        y_max = np.max(y)
        y_half = y_min + 0.5 * (y_max - y_min)

        # Find closest point
        idx = np.argmin(np.abs(y - y_half))
        t_trans.append(time[idx])

    return np.array(t_trans)


# --- COMPUTE ---
