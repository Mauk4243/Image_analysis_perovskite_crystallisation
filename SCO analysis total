    baseline = np.mean(data[10:20, :], axis=0)
    data = data - baseline

    t_trans = []

    for i in range(data.shape[1]):
        y = data[:, i]

        # Define 50% level
        y_min = np.min(y)
        y_max = np.max(y)
        y_half = y_min + 0.5 * (y_max - y_min)

        # Find closest point
        idx = np.argmin(np.abs(y - y_half))
        t_trans.append(time[idx])

    return np.array(t_trans)


# --- COMPUTE ---
t_h = get_transition_times(horizontal_coords)
t_v = get_transition_times(vertical_coords)
t_d = get_transition_times(diag_coords)

