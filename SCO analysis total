images = xarr_dat['images']
time = images['time'].values

# --- PARAMETERS ---
y0 = 250
x0 = 250
n_points = 50

# Transition window
t_min, t_max = 60, 125

# --- COORDINATES ---
x_vals = np.linspace(0, images.shape[2]-1, n_points).astype(int)
y_vals = np.linspace(0, images.shape[1]-1, n_points).astype(int)

horizontal_coords = [(y0, x) for x in x_vals]
vertical_coords   = [(y, x0) for y in y_vals]
diag_coords       = list(zip(y_vals, x_vals))


# --- FUNCTION: slope via linear fit ---
def get_slope_profile(coords, sigma=3):
    data = np.array([images[:, y, x] for (y, x) in coords]).T

    # Smooth
    data = gaussian_filter1d(data, sigma=sigma, axis=0)

    # Normalize
    baseline = np.mean(data[10:20, :], axis=0)
    data = data - baseline

    # Select transition window
    mask = (time >= t_min) & (time <= t_max)
    t_fit = time[mask]

    slopes = []

    for i in range(data.shape[1]):
        y_fit = data[mask, i]

        # Linear fit: y = a*t + b
        a, b = np.polyfit(t_fit, y_fit, 1)
        slopes.append(a)

    return np.array(slopes)


# --- COMPUTE ---
