import numpy as np
import matplotlib.pyplot as plt

plt.figure(figsize=(8, 5))

# Filter data to your growth window (0 to 20s)
fit_mask = (times >= 0) & (times <= 20)
t_fit = times[fit_mask]
a_fit = area_growth[fit_mask]

# ============================================================
# LINEAR TRANSFORMATION (SQUARE ROOT)
# ============================================================
# Take the square root of the area data to linearize it
linear_data = np.sqrt(a_fit)

# Perform a linear fit: y = m*t + c
# m = linear growth rate (um/s), c = intercept
slope, intercept = np.polyfit(t_fit, linear_data, 1)

# Evaluate the model line across a smooth timeline
t_smooth = np.linspace(0, 20, 500)
linear_modeled_smooth = slope * t_smooth + intercept

# ============================================================
# CALCULATION OF UNCERTAINTY (STANDARD ERROR OF SLOPE)
# ============================================================
# Calculate residuals in the linearized domain
linear_modeled_sparse = slope * t_fit + intercept
residuals_linear = linear_data - linear_modeled_sparse
std_dev_linear = np.std(residuals_linear)

# Standard error of the slope (growth rate uncertainty)
n = len(t_fit)
x_mean = np.mean(t_fit)
slope_uncertainty = std_dev_linear / np.sqrt(np.sum((t_fit - x_mean)**2))

# Print the physical metrics for your conclusion
print(f"Linear Growth Rate (m) = {slope:.4f} ± {slope_uncertainty:.4f} μm/s")
print(f"Linear Residual Noise Floor = {std_dev_linear:.4f} μm")

# ============================================================
# PLOTTING
# ============================================================
# Plot the square-root transformed data points
plt.plot(times, np.sqrt(area_growth), 'o', color='black', markersize=7, alpha=0.7, label='$\sqrt{\text{Area}}$ Data')

# Plot the linear growth rate model
plt.plot(t_smooth, linear_modeled_smooth, color='red', linewidth=2, 
         label=f'Linear Fit (Rate: {slope:.3f} $\mu$m/s)')

# Shaded uncertainty bands in the linear domain
plt.fill_between(t_smooth, linear_modeled_smooth - std_dev_linear, linear_modeled_smooth + std_dev_linear, 
                 color='red', alpha=0.15, label=f'1$\sigma$ Noise Band ($\pm${std_dev_linear:.3f} $\mu$m)')
plt.fill_between(t_smooth, linear_modeled_smooth - 2*std_dev_linear, linear_modeled_smooth + 2*std_dev_linear, 
                 color='red', alpha=0.05, label=f'2$\sigma$ Noise Band ($\pm${2*std_dev_linear:.3f} $\mu$m)')

# Transformed Diffraction Limits (Square root of original area limits)
# If original limits were Area = 2.83 and 1.90:
plt.axhline(y=np.sqrt(2.83), color='blue', linestyle='--', linewidth=1.5, label='Rayleigh Limit ($\sqrt{2.83}$ $\mu$m)')
plt.axhline(y=np.sqrt(1.90), color='purple', linestyle=':', linewidth=1.5, label='Abbe Limit ($\sqrt{1.90}$ $\mu$m)')

plt.xlim(0, 20)
plt.grid(True, linestyle='--', alpha=0.5)
plt.xlabel("Time [s]")
plt.ylabel(r"Effective Radius $\sqrt{\text{Area}}$ [$\mu$m]")
plt.legend(loc='lower right')
plt.savefig("linear_growth_rate.pdf", bbox_inches='tight')

plt.show()






