def select_multiple_rois(image, title="Select Multiple ROIs"):

    fig, ax = plt.subplots()
    ax.imshow(image, cmap='gray')
    ax.set_title(title)
    rois = []
    # Add a button/key to finish the selection of ROIs, so that the user can select 
    # as many ROIs as they want and then press Enter to finish the selection
    def on_key(event):
        if event.key == 'enter':
            plt.close(fig)
    fig.canvas.mpl_connect('key_press_event', on_key)
    while True:
        roi = plt.ginput(2, timeout=-1)  # Wait for user to draw a rectangle with two clicks
        if len(roi) == 2:
            x_min = int(min(roi[0][0], roi[1][0]))
            x_max = int(max(roi[0][0], roi[1][0]))
            y_min = int(min(roi[0][1], roi[1][1]))
            y_max = int(max(roi[0][1], roi[1][1]))
            rois.append({'xmin': x_min, 'xmax': x_max, 'ymin': y_min, 'ymax': y_max})
            # Draw the rectangle on the image to show the selection
            rect = Rectangle((x_min, y_min), x_max - x_min, y_max - y_min,
                             edgecolor='red', facecolor='none', linewidth=2)
            ax.add_patch(rect)
            plt.draw()
        else:
            print("No valid ROI selected. Ending selection.")
            break
    
    plt.close(fig)
    return rois

