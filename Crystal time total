# PLATEAU TIME ANALYSIS
# Plotting the other dataset with the same code to compare the difference between the two files.

images = iscat_data

times = iscat_arr['time'].values

from scipy.ndimage import gaussian_filter1d
import numpy as np
import matplotlib.pyplot as plt

# ============================================================
# PARAMETERS
# ============================================================

block_size = 1
smooth_sigma = 0.1
epsilon = 0.04
min_consecutive = 20

# ============================================================
# ENSURE CONSISTENT LENGTHS
# ============================================================

n_frames = min(images.shape[0], len(times))
images = images[:n_frames]
times = times[:n_frames]

# ============================================================
# COARSE GRAINING
# ============================================================

coarse = images.coarsen(
    x=block_size,
    y=block_size,
    boundary='trim'
).mean()

coarse_data = coarse.values
n_time, ny, nx = coarse_data.shape

# ============================================================
# STORAGE DATASET 1
# ============================================================

crystal_mask = np.zeros((ny, nx), dtype=bool)
crystallisation_time = np.full((ny, nx), np.nan)
trace_array = np.zeros((ny, nx, n_time))

# ============================================================
# MAIN LOOP DATASET 1
# ============================================================

for iy in range(ny):

    for ix in range(nx):

        trace = coarse_data[:, iy, ix].astype(float)

        if trace[0] == 0:
            continue

        trace = (
            trace - trace[0]
        ) / np.abs(trace[0])

        trace_smooth = gaussian_filter1d(
            trace,
            sigma=smooth_sigma
        )

        trace_array[iy, ix] = trace_smooth

        I_final = np.median(trace_smooth[-30:])
        I_initial = np.mean(trace_smooth[:10])

        net_change = abs(I_final - I_initial)

        if net_change < 0.03:   #set this to 0.01
            continue

        distance = np.abs(
            trace_smooth - I_final
        )

        inside = distance < epsilon

        count = 0

        for t in range(n_time):

            if inside[t]:
                count += 1
            else:
                count = 0

            if count >= min_consecutive:

                crystal_mask[iy, ix] = True

                crystallisation_frame = (
                    t - min_consecutive + 1
                )

                crystallisation_time[iy, ix] = (
                    times[crystallisation_frame]
                )

                break


# ============================================================
# VISUALIZE CRYSTALLISATION TIME MAPS
# ============================================================
