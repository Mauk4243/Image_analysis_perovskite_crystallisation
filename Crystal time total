# %%
import numpy as np
import matplotlib.pyplot as plt

plt.figure(figsize=(8, 5))

# 1. Plot your original area growth data
plt.plot(times, area_growth, label='Data', color='black', alpha=0.7)

# ============================================================
# QUADRATIC FITTING & STANDARD DEVIATION BANDS
# ============================================================
# Crop data to match your visual x-limits (0 to 20s) for an accurate fit
fit_mask = (times >= 0) & (times <= 20)
t_fit = times[fit_mask]
a_fit = area_growth[fit_mask]

if len(t_fit) > 2:
    # Perform the quadratic fit (degree = 2)
    # Returns coefficients [a, b, c] for a*t^2 + b*t + c
    coefficients = np.polyfit(t_fit, a_fit, 2)
    
    # Evaluate the quadratic model over the fitted time points
    area_modeled = np.polyval(coefficients, t_fit)
    
    # Calculate the standard deviation (σ) of the residuals (noise)
    residuals = a_fit - area_modeled
    std_dev = np.std(residuals)
    
    # Plot the quadratic fit line
    plt.plot(t_fit, area_modeled, color='red', linewidth=2, 
             label='Quadratic Fit')
    
    # Plot Shaded Standard Deviation Bands
    plt.fill_between(t_fit, area_modeled - std_dev, area_modeled + std_dev, 
                     color='red', alpha=0.15, label=f'1$\sigma$ Band ($\pm${std_dev:.3f} $\mu$m$^2$)')
    plt.fill_between(t_fit, area_modeled - 2*std_dev, area_modeled + 2*std_dev, 
                     color='red', alpha=0.05, label=f'2$\sigma$ Band ($\pm${2*std_dev:.3f} $\mu$m$^2$)')
    
    print(f"Fit Equation: Area = {coefficients[0]:.4f}*t² + {coefficients[1]:.4f}*t + {coefficients[2]:.4f}")
    print(f"Standard Deviation of Residuals (Noise Floor) = {std_dev:.4f} μm²")

# ============================================================
# PLOT STYLING
# ============================================================
plt.ylim(0, 6)
plt.xlim(0, 20)  
plt.grid(True, linestyle='--', alpha=0.5)

plt.xlabel("Time [s]")
plt.ylabel(r"Area [$\mu$m$^2$]")
plt.legend(loc='upper left')

plt.show()






